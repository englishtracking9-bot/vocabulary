[
  { "affix": "un", "type": "prefix", "meaning": "不、相反", "examples": ["unhappy", "unable", "unfair", "unlock", "unknown"], "note": "最常見的否定字首，un + 形容詞＝相反意思" },
  { "affix": "in", "type": "prefix", "meaning": "不、向內", "examples": ["incorrect", "invisible", "income", "indoor"], "note": "可表否定(incorrect)或向內(income 收入)" },
  { "affix": "im", "type": "prefix", "meaning": "不（用在 m/p/b 前）", "examples": ["impossible", "impolite", "imperfect", "import"], "note": "in- 在 m/p/b 前會變 im-，較好發音" },
  { "affix": "il", "type": "prefix", "meaning": "不（用在 l 前）", "examples": ["illegal", "illogical"], "note": "in- 在 l 前變 il-：illegal 不合法" },
  { "affix": "ir", "type": "prefix", "meaning": "不（用在 r 前）", "examples": ["irregular", "irresponsible"], "note": "in- 在 r 前變 ir-：irregular 不規則" },
  { "affix": "dis", "type": "prefix", "meaning": "不、相反、分開", "examples": ["disagree", "disappear", "dishonest", "disconnect", "dislike"], "note": "dis + 動詞/形容詞＝相反，如 disagree 不同意" },
  { "affix": "non", "type": "prefix", "meaning": "非、無", "examples": ["nonstop", "nonsense", "nonprofit"], "note": "non = 沒有：nonstop 不停的" },
  { "affix": "mis", "type": "prefix", "meaning": "錯誤地", "examples": ["mistake", "misunderstand", "misuse", "mislead"], "note": "mis = 弄錯：mistake 錯誤、misunderstand 誤會" },
  { "affix": "anti", "type": "prefix", "meaning": "反對、抵抗", "examples": ["antiwar", "antibody", "antisocial"], "note": "anti = 反：antiwar 反戰" },
  { "affix": "re", "type": "prefix", "meaning": "再一次、回", "examples": ["return", "repeat", "rewrite", "rebuild", "review"], "note": "re = 再/回：return 返回、repeat 重複" },
  { "affix": "pre", "type": "prefix", "meaning": "在…之前", "examples": ["prepare", "preview", "predict", "prevent", "preschool"], "note": "pre = 前：preview 預習、predict 預測" },
  { "affix": "post", "type": "prefix", "meaning": "在…之後", "examples": ["postpone", "postwar"], "note": "post = 後：postpone 延後" },
  { "affix": "fore", "type": "prefix", "meaning": "預先、前面", "examples": ["forecast", "foresee", "forehead"], "note": "fore = 前：forecast 預報" },
  { "affix": "ex", "type": "prefix", "meaning": "向外、出", "examples": ["export", "exit", "expand", "explode", "external"], "note": "ex = 外：export 出口、exit 出口" },
  { "affix": "trans", "type": "prefix", "meaning": "橫越、轉換", "examples": ["transport", "transfer", "translate", "transform"], "note": "trans = 跨越：transport 運輸、translate 翻譯（轉換語言）" },
  { "affix": "inter", "type": "prefix", "meaning": "在…之間、互相", "examples": ["international", "internet", "interview", "interact"], "note": "inter = 之間：international 國際的（國與國之間）" },
  { "affix": "sub", "type": "prefix", "meaning": "在…之下、次", "examples": ["subway", "submarine", "subject", "subtract"], "note": "sub = 下：subway 地下鐵、submarine 潛水艇" },
  { "affix": "super", "type": "prefix", "meaning": "超越、在上", "examples": ["superman", "supermarket", "superior", "supervise"], "note": "super = 超：supermarket 超級市場" },
  { "affix": "con", "type": "prefix", "meaning": "共同、一起", "examples": ["connect", "contact", "conference", "combine", "company"], "note": "con/com = 一起：connect 連接、combine 結合" },
  { "affix": "pro", "type": "prefix", "meaning": "向前、贊成", "examples": ["progress", "produce", "project", "promote", "protect"], "note": "pro = 前：progress 進步（向前走）" },
  { "affix": "de", "type": "prefix", "meaning": "向下、除去、相反", "examples": ["decrease", "destroy", "defrost", "decode"], "note": "de = 下/去除：decrease 減少、destroy 破壞" },
  { "affix": "uni", "type": "prefix", "meaning": "一、單一", "examples": ["uniform", "unique", "unite", "universe"], "note": "uni = 一：uniform 制服（統一形式）、unite 聯合" },
  { "affix": "bi", "type": "prefix", "meaning": "二、雙", "examples": ["bicycle", "bilingual"], "note": "bi = 二：bicycle 腳踏車（兩個輪子）" },
  { "affix": "tri", "type": "prefix", "meaning": "三", "examples": ["triangle", "tricycle"], "note": "tri = 三：triangle 三角形" },
  { "affix": "multi", "type": "prefix", "meaning": "多", "examples": ["multiple", "multimedia"], "note": "multi = 多：multiple 多重的" },
  { "affix": "auto", "type": "prefix", "meaning": "自己、自動", "examples": ["automatic", "automobile", "autograph"], "note": "auto = 自己：automatic 自動的" },
  { "affix": "tele", "type": "prefix", "meaning": "遠距離", "examples": ["telephone", "television", "telescope"], "note": "tele = 遠：telephone 電話（遠處傳聲）、telescope 望遠鏡" },
  { "affix": "micro", "type": "prefix", "meaning": "微小", "examples": ["microphone", "microscope", "microwave"], "note": "micro = 微：microscope 顯微鏡" },
  { "affix": "semi", "type": "prefix", "meaning": "一半", "examples": ["semicircle"], "note": "semi = 半：semicircle 半圓" },
  { "affix": "over", "type": "prefix", "meaning": "過度、上方", "examples": ["overcome", "overlook", "overweight", "oversleep"], "note": "over = 過度：overweight 超重、oversleep 睡過頭" },
  { "affix": "under", "type": "prefix", "meaning": "在…之下、不足", "examples": ["understand", "underground", "underline"], "note": "under = 下：underground 地下的、underline 畫底線" },

  { "affix": "port", "type": "root", "meaning": "攜帶、運送", "examples": ["transport", "export", "import", "portable", "support", "report"], "note": "想到 airport 機場＝運送旅客的地方；port 就是搬運" },
  { "affix": "spect", "type": "root", "meaning": "看", "examples": ["respect", "inspect", "expect", "spectator", "perspective"], "note": "spect = 看：inspect 檢查（仔細看）、spectator 觀眾" },
  { "affix": "dict", "type": "root", "meaning": "說", "examples": ["predict", "dictionary", "dictation", "contradict"], "note": "dict = 說：dictionary 字典（教你怎麼說）、predict 預言" },
  { "affix": "scrib", "type": "root", "meaning": "寫", "examples": ["describe", "subscribe", "prescribe"], "note": "scrib/script = 寫：describe 描述、subscribe 訂閱（在下面簽名）" },
  { "affix": "script", "type": "root", "meaning": "寫", "examples": ["describe", "subscribe", "manuscript"], "note": "script = 寫成的文字：manuscript 手稿" },
  { "affix": "form", "type": "root", "meaning": "形狀、形成", "examples": ["uniform", "transform", "inform", "reform", "formula"], "note": "form = 形：transform 變形、uniform 制服（同一形狀）" },
  { "affix": "struct", "type": "root", "meaning": "建造", "examples": ["construct", "structure", "instruct", "destruction"], "note": "struct = 建：construct 建造、structure 結構" },
  { "affix": "vert", "type": "root", "meaning": "轉", "examples": ["convert", "advertise", "introvert"], "note": "vert = 轉：convert 轉換" },
  { "affix": "ject", "type": "root", "meaning": "丟、投", "examples": ["project", "reject", "inject", "object"], "note": "ject = 丟：reject 拒絕（丟回去）、inject 注射（丟進去）" },
  { "affix": "tract", "type": "root", "meaning": "拉", "examples": ["attract", "subtract", "extract", "tractor"], "note": "tract = 拉：attract 吸引（拉過來）、tractor 拖拉機" },
  { "affix": "duct", "type": "root", "meaning": "引導", "examples": ["produce", "reduce", "introduce", "conduct", "educate"], "note": "duc/duct = 引導：introduce 介紹（引進來）、produce 生產" },
  { "affix": "mit", "type": "root", "meaning": "送、放", "examples": ["admit", "permit", "submit", "transmit"], "note": "mit/miss = 送：submit 提交（送上去）、permit 允許" },
  { "affix": "miss", "type": "root", "meaning": "送、放", "examples": ["mission", "permission", "dismiss", "missile"], "note": "miss = 送：mission 任務（被送去做的事）、dismiss 解散" },
  { "affix": "pos", "type": "root", "meaning": "放置", "examples": ["position", "compose", "expose", "purpose", "deposit"], "note": "pos = 放：position 位置（放的地方）、compose 組成（放在一起）" },
  { "affix": "tain", "type": "root", "meaning": "握住、保持", "examples": ["contain", "maintain", "obtain", "retain"], "note": "tain/ten = 握：contain 包含（握住裡面）、maintain 維持" },
  { "affix": "fer", "type": "root", "meaning": "帶、拿", "examples": ["transfer", "offer", "prefer", "differ", "suffer"], "note": "fer = 帶：transfer 轉移、prefer 較喜歡（帶在前面）" },
  { "affix": "vis", "type": "root", "meaning": "看", "examples": ["visible", "vision", "visit", "television", "supervise"], "note": "vis/vid = 看：visible 看得見的、vision 視力" },
  { "affix": "vid", "type": "root", "meaning": "看", "examples": ["video", "evidence", "provide"], "note": "vid = 看：video 影像、evidence 證據（看得到的東西）" },
  { "affix": "aud", "type": "root", "meaning": "聽", "examples": ["audio", "audience", "auditorium"], "note": "aud = 聽：audience 觀眾/聽眾、audio 音訊" },
  { "affix": "graph", "type": "root", "meaning": "寫、畫、記錄", "examples": ["photograph", "geography", "autograph", "paragraph"], "note": "graph = 記錄：photograph 照片（用光記錄）、geography 地理" },
  { "affix": "log", "type": "root", "meaning": "話語、學問", "examples": ["dialogue", "biology", "apology", "logic"], "note": "log = 學問：biology 生物學、dialogue 對話" },
  { "affix": "phon", "type": "root", "meaning": "聲音", "examples": ["telephone", "microphone", "symphony"], "note": "phon = 聲：telephone 電話、microphone 麥克風" },
  { "affix": "photo", "type": "root", "meaning": "光", "examples": ["photograph", "photo", "photography"], "note": "photo = 光：photograph 照片" },
  { "affix": "geo", "type": "root", "meaning": "土地、地球", "examples": ["geography", "geology"], "note": "geo = 地：geography 地理學" },
  { "affix": "bio", "type": "root", "meaning": "生命", "examples": ["biology", "biography"], "note": "bio = 生命：biology 生物學、biography 傳記（寫人的一生）" },
  { "affix": "therm", "type": "root", "meaning": "熱", "examples": ["thermometer", "thermos"], "note": "therm = 熱：thermometer 溫度計" },
  { "affix": "manu", "type": "root", "meaning": "手", "examples": ["manual", "manufacture", "manuscript"], "note": "manu = 手：manual 手冊/手動的、manufacture 製造（原意手工做）" },
  { "affix": "ped", "type": "root", "meaning": "腳", "examples": ["pedal", "pedestrian"], "note": "ped = 腳：pedal 踏板、pedestrian 行人" },
  { "affix": "cent", "type": "root", "meaning": "百", "examples": ["century", "percent", "centimeter"], "note": "cent = 百：century 世紀（一百年）、percent 百分比" },

  { "affix": "able", "type": "suffix", "meaning": "可…的、能…的", "examples": ["comfortable", "available", "reasonable", "valuable", "portable"], "note": "-able 接動詞變形容詞：comfortable 舒適的、portable 可攜帶的" },
  { "affix": "ible", "type": "suffix", "meaning": "可…的、能…的", "examples": ["possible", "visible", "terrible", "responsible"], "note": "-ible 同 -able：visible 看得見的" },
  { "affix": "ful", "type": "suffix", "meaning": "充滿…的", "examples": ["beautiful", "careful", "helpful", "wonderful", "powerful"], "note": "-ful = 充滿：helpful 有幫助的、careful 小心的" },
  { "affix": "less", "type": "suffix", "meaning": "沒有…的", "examples": ["careless", "hopeless", "homeless", "useless", "endless"], "note": "-less = 沒有：careless 粗心的、homeless 無家的（與 -ful 相反）" },
  { "affix": "ness", "type": "suffix", "meaning": "…的狀態（名詞）", "examples": ["happiness", "kindness", "darkness", "illness", "weakness"], "note": "-ness 把形容詞變名詞：happy→happiness 快樂" },
  { "affix": "ment", "type": "suffix", "meaning": "…的結果/行為（名詞）", "examples": ["development", "government", "movement", "agreement", "payment"], "note": "-ment 把動詞變名詞：develop→development 發展" },
  { "affix": "tion", "type": "suffix", "meaning": "…的行為/狀態（名詞）", "examples": ["education", "information", "action", "attention", "invitation"], "note": "-tion/-sion 把動詞變名詞：educate→education 教育" },
  { "affix": "sion", "type": "suffix", "meaning": "…的行為/狀態（名詞）", "examples": ["decision", "discussion", "permission", "television"], "note": "-sion：decide→decision 決定" },
  { "affix": "er", "type": "suffix", "meaning": "做…的人/物", "examples": ["teacher", "worker", "singer", "writer", "driver"], "note": "-er = 人：teach→teacher 老師" },
  { "affix": "or", "type": "suffix", "meaning": "做…的人/物", "examples": ["actor", "doctor", "visitor", "inventor", "director"], "note": "-or = 人：act→actor 演員" },
  { "affix": "ist", "type": "suffix", "meaning": "從事…的人", "examples": ["artist", "scientist", "tourist", "pianist", "dentist"], "note": "-ist = 專家：art→artist 藝術家" },
  { "affix": "ity", "type": "suffix", "meaning": "…的性質（名詞）", "examples": ["ability", "activity", "reality", "quality", "safety"], "note": "-ity 把形容詞變名詞：able→ability 能力" },
  { "affix": "ous", "type": "suffix", "meaning": "充滿…的（形容詞）", "examples": ["dangerous", "famous", "nervous", "serious", "various"], "note": "-ous = 多…的：danger→dangerous 危險的" },
  { "affix": "ive", "type": "suffix", "meaning": "有…性質的（形容詞）", "examples": ["active", "creative", "positive", "expensive", "attractive"], "note": "-ive：act→active 活躍的" },
  { "affix": "al", "type": "suffix", "meaning": "…的（形容詞）", "examples": ["natural", "national", "personal", "musical", "traditional"], "note": "-al 把名詞變形容詞：nature→natural 自然的" },
  { "affix": "ize", "type": "suffix", "meaning": "使…化（動詞）", "examples": ["realize", "organize", "recognize", "memorize"], "note": "-ize = 使變成：real→realize 領悟、memorize 背起來" },
  { "affix": "ify", "type": "suffix", "meaning": "使…（動詞）", "examples": ["simplify", "satisfy", "identify"], "note": "-ify = 使：simple→simplify 簡化" },
  { "affix": "ly", "type": "suffix", "meaning": "…地（副詞）", "examples": ["quickly", "slowly", "happily", "carefully", "really"], "note": "-ly 把形容詞變副詞：quick→quickly 快速地" },
  { "affix": "teen", "type": "suffix", "meaning": "十幾（13–19）", "examples": ["thirteen", "fourteen", "fifteen", "sixteen", "seventeen", "eighteen", "nineteen"], "note": "-teen = 十幾：thirteen 13、nineteen 19" }
]
